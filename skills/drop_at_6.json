{
  "name": "drop_at_6",
  "description": "Carry to position 6, open to drop, then lift the claw clear of the cube.",
  "notes": "Place = pos -> release -> lift-away (raise shoulder, retract elbow, wrist up) so the return move doesn't drag the dropped cube.",
  "steps": [
    {
      "tool": "move_to",
      "args": {
        "target": {
          "shoulder_pan.pos": 30.065934065934066,
          "shoulder_lift.pos": 9.45054945054945,
          "elbow_flex.pos": 31.164835164835164,
          "wrist_flex.pos": 67.86813186813187,
          "wrist_roll.pos": -70.72527472527473
        }
      }
    },
    {
      "tool": "set_gripper",
      "args": {
        "position": 60
      }
    },
    {
      "tool": "move_relative",
      "args": {
        "delta": {
          "shoulder_lift.pos": -18,
          "elbow_flex.pos": 18,
          "wrist_flex.pos": -28
        },
        "tolerance": 1.5,
        "timeout": 3.0
      }
    },
    {
      "tool": "wait_until_settled",
      "args": {
        "timeout": 0.8
      }
    }
  ]
}