{
  "name": "drop_at_5",
  "description": "Carry to position 5, open to drop, then lift the claw clear of the cube.",
  "notes": "Place = pos -> release -> lift-away (raise shoulder, retract elbow, wrist up) so the return move doesn't drag the dropped cube.",
  "steps": [
    {
      "tool": "move_to",
      "args": {
        "target": {
          "shoulder_pan.pos": 1.054945054945055,
          "shoulder_lift.pos": -4.175824175824176,
          "elbow_flex.pos": 47.51648351648352,
          "wrist_flex.pos": 59.252747252747255,
          "wrist_roll.pos": -102.02197802197803
        }
      }
    },
    {
      "tool": "set_gripper",
      "args": {
        "position": 60
      }
    },
    {
      "tool": "move_relative",
      "args": {
        "delta": {
          "shoulder_lift.pos": -18,
          "elbow_flex.pos": 18,
          "wrist_flex.pos": -28
        },
        "tolerance": 1.5,
        "timeout": 3.0
      }
    },
    {
      "tool": "wait_until_settled",
      "args": {
        "timeout": 0.8
      }
    }
  ]
}