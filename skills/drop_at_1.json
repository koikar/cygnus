{
  "name": "drop_at_1",
  "description": "Carry to position 1, open to drop, then lift the claw clear of the cube.",
  "notes": "Place = pos -> release -> lift-away (raise shoulder, retract elbow, wrist up) so the return move doesn't drag the dropped cube.",
  "steps": [
    {
      "tool": "move_to",
      "args": {
        "target": {
          "shoulder_pan.pos": 16.791208791208792,
          "shoulder_lift.pos": 41.62637362637363,
          "elbow_flex.pos": -21.75824175824176,
          "wrist_flex.pos": 80.96703296703296,
          "wrist_roll.pos": -80.3956043956044
        }
      }
    },
    {
      "tool": "set_gripper",
      "args": {
        "position": 60
      }
    },
    {
      "tool": "move_relative",
      "args": {
        "delta": {
          "shoulder_lift.pos": -18,
          "elbow_flex.pos": 18,
          "wrist_flex.pos": -28
        },
        "tolerance": 1.5,
        "timeout": 3.0
      }
    },
    {
      "tool": "wait_until_settled",
      "args": {
        "timeout": 0.8
      }
    }
  ]
}